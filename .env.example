# Forza Horizon 6 Telemetry Dashboard — configuration
# Copy to .env or set these in docker-compose.yml.

# Web dashboard port (HTTP + WebSocket)
WEB_PORT=8080

# UDP listener for Forza "Data Out" telemetry
UDP_HOST=0.0.0.0
UDP_PORT=20440

# Where sessions, map tiles and settings are stored
DATA_DIR=/data

# A session ends after this many seconds without telemetry packets
SESSION_TIMEOUT_SECONDS=30

# gzip telemetry.jsonl once a session finishes
COMPRESS_FINISHED_SESSIONS=false

# Allow DELETE /api/sessions/:id
ALLOW_DELETE_SESSIONS=false

# Ignore packets from any sender other than the first one seen
LOCK_TO_FIRST_SENDER=false

# Log level: trace | debug | info | warn | error | silent
LOG_LEVEL=info

# Live WebSocket broadcast rate (Hz); recording always stays at full 60 Hz
BROADCAST_HZ=30

# Track map. Tiles are cached lazily on demand as the map is viewed;
# MAP_AUTODOWNLOAD_TILES additionally runs a full bulk pre-download on startup.
MAP_ENABLED=true
MAP_AUTODOWNLOAD_TILES=false
MAP_TILES_URL=https://tiles.mapgenie.io/games/forza-horizon-6/one/default-v2/{z}/{y}/{x}.jpg

# Maximum sessions returned by GET /api/sessions
MAX_SESSION_LIST_ITEMS=500
