{
  "name": "fh6-telemetry-dashboard",
  "version": "0.1.0",
  "private": true,
  "description": "Forza Horizon 6 telemetry dashboard: live UDP telemetry, session recording and replay in a self-hosted container",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "run-p dev:server dev:client",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "vite",
    "build": "run-s build:client build:server",
    "build:client": "vite build",
    "build:server": "esbuild src/server/index.ts --bundle --platform=node --format=cjs --target=node20 --outfile=dist/server/index.js --packages=external",
    "start": "node dist/server/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "capture": "tsx src/server/tools/capturePacket.ts",
    "download-tiles": "tsx src/server/tools/downloadTiles.ts",
    "update-cars": "node scripts/build-car-lookup.mjs",
    "build:favicons": "python3 scripts/build-favicons.py"
  },
  "dependencies": {
    "@fastify/static": "^8.0.4",
    "fastify": "^5.2.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@testing-library/react": "^16.1.0",
    "@types/leaflet": "^1.9.16",
    "@types/node": "^22.10.7",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "esbuild": "^0.24.2",
    "eslint": "^9.18.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "globals": "^15.14.0",
    "jsdom": "^26.0.0",
    "leaflet": "^1.9.4",
    "npm-run-all2": "^7.0.2",
    "postcss": "^8.5.1",
    "prettier": "^3.4.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vite": "^6.0.7",
    "vitest": "^2.1.8",
    "zustand": "^5.0.3"
  }
}
